<script>
(function(){
  var steps = Array.prototype.slice.call(document.querySelectorAll('.step'));
  var navLinks = Array.prototype.slice.call(document.querySelectorAll('.quicknav a'));
  var total = steps.length;
  var current = 1;

  function showStep(n){
    if(n < 1) n = 1;
    if(n > total) n = total;
    current = n;
    steps.forEach(function(s, i){
      s.classList.toggle('active', (i+1) === n);
    });
    navLinks.forEach(function(a, i){
      a.classList.toggle('cur', (i+1) === n);
    });
    var curLink = navLinks[n-1];
    if(curLink && curLink.scrollIntoView){
      curLink.scrollIntoView({behavior:'smooth', inline:'center', block:'nearest'});
    }
    var stepsWrap = document.querySelector('.steps');
    if(stepsWrap){
      var top = stepsWrap.getBoundingClientRect().top + window.scrollY - 60;
      window.scrollTo({top: top, behavior:'smooth'});
    }
    history.replaceState(null, '', '#step-' + n);
  }

  navLinks.forEach(function(a, i){
    a.addEventListener('click', function(e){
      e.preventDefault();
      showStep(i + 1);
    });
  });

  steps.forEach(function(step, i){
    var prevBtn = step.querySelector('.nav-btn.prev');
    var nextBtn = step.querySelector('.nav-btn.next');
    if(prevBtn){
      prevBtn.addEventListener('click', function(){ showStep(current - 1); });
    }
    if(nextBtn){
      nextBtn.addEventListener('click', function(){
        if(current === total){ showStep(1); } else { showStep(current + 1); }
      });
    }
  });

  var startAt = 1;
  var hash = window.location.hash;
  if(hash && /^#step-\d+$/.test(hash)){
    var n = parseInt(hash.replace('#step-',''), 10);
    if(n >= 1 && n <= total) startAt = n;
  }
  showStep(startAt);
})();
</script>

